{
  "name": "@gearu/core",
  "version": "1.5.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./trpc": {
      "types": "./dist/trpc/index.d.ts",
      "import": "./dist/trpc/index.js",
      "default": "./dist/trpc/index.js"
    },
    "./auth/client": {
      "types": "./dist/auth/client.d.ts",
      "import": "./dist/auth/client.js",
      "default": "./dist/auth/client.js"
    },
    "./auth/server": {
      "types": "./dist/auth/server.d.ts",
      "import": "./dist/auth/server.js",
      "default": "./dist/auth/server.js"
    },
    "./db/libsql": {
      "types": "./dist/db-libsql.d.ts",
      "import": "./dist/db-libsql.js",
      "default": "./dist/db-libsql.js"
    },
    "./schema": {
      "types": "./dist/schema-entry.d.ts",
      "import": "./dist/schema-entry.js",
      "default": "./dist/schema-entry.js"
    },
    "./seo": {
      "types": "./dist/seo-entry.d.ts",
      "import": "./dist/seo-entry.js",
      "default": "./dist/seo-entry.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check:auth-boundary": "node scripts/check-auth-bundle-boundary.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "superjson": "^2.2.2",
    "zod": "^4.3.6"
