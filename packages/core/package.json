  "peerDependencies": {
    "@libsql/client": "^0.15.0",
    "@tanstack/react-start": "*",
    "@trpc/server": "^11.11.0",
    "better-sqlite3": "*",
    "better-auth": "^1.5.3",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@libsql/client": "^0.15.15",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "22.x"
  }
