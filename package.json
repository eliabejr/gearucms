{
  "name": "gearu-cms",
  "author": "Eliabe Serafim Jr <eliabejr@proton.me>",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:setup": "dotenv -e .env.local -- tsx scripts/setup-dev-db.ts",
    "db:setup:seed": "dotenv -e .env.local -- tsx scripts/setup-dev-db.ts --seed",
    "db:setup:reset": "dotenv -e .env.local -- tsx scripts/setup-dev-db.ts --reset --seed",
    "build:cf": "DEPLOY_TARGET=cloudflare vite build",
    "d1:migrate:local": "npx wrangler d1 migrations apply eli-cms-db --local",
    "d1:migrate:remote": "npx wrangler d1 migrations apply eli-cms-db --remote",
    "gearu": "gearu"
  },
  "dependencies": {
    "@gearu/admin": "workspace:*",
    "@gearu/core": "workspace:*",
    "@gearu/plugin-analytics": "workspace:*",
    "@gearu/plugin-leads": "workspace:*",
    "gearu": "workspace:*",
    "@faker-js/faker": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/ai": "latest",
    "@tanstack/ai-anthropic": "latest",
    "@tanstack/ai-client": "latest",
    "@tanstack/ai-gemini": "latest",
    "@tanstack/ai-ollama": "latest",
    "@tanstack/ai-openai": "latest",
    "@tanstack/ai-react": "latest",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "latest",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "better-auth": "^1.5.3",
    "better-sqlite3": "^12.6.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-select": "^5.9.0",
    "streamdown": "^2.3.0",
    "superjson": "^2.2.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@inlang/paraglide-js": "^2.13.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.14.0",
    "@cloudflare/workers-types": "^4.20250303.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "better-sqlite3",
      "esbuild",
      "lightningcss",
      "prisma",
      "protobufjs"
    ]
  }
}